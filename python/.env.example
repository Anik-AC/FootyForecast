# Copy this file to .env and fill in real values. Never commit .env.
#
# DATABASE_URL: connection string for the local Postgres dev database.
#   Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#   Example: postgresql://postgres:postgres@localhost:5432/footyforecast_dev
#
# APIFOOTBALL_KEY: API key from https://dashboard.api-football.com/
#   Used by footy/ingest/wc2026.py to fetch WC 2026 fixtures and live results.
#   Free tier allows 100 requests/day. The script caches responses to
#   data/wc2026_fixtures_cache.json; delete the cache file to force a re-fetch.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/footyforecast_dev

# football-data.org free tier (covers FIFA World Cup).
# Register at https://www.football-data.org/client/register
FOOTBALLDATA_KEY=your_footballdata_key_here

# api-football.com key (kept for reference; free plan blocks season 2026).
# APIFOOTBALL_KEY=your_api_football_key_here

# Kalshi bearer token for market data ingestion (optional).
# Note: Kalshi does not allow accounts from Canada. Leave this unset if you
# are in Canada — footy/ingest/markets.py will skip Kalshi silently and
# fetch Polymarket only. No code changes required.
# KALSHI_API_KEY=your_kalshi_api_key_here

# OpenRouter API key for LLM match preview generation (footy/previews.py).
# Free tier available — sign up at https://openrouter.ai
# Previews use meta-llama/llama-3.1-8b-instruct:free by default (no cost).
# Change the --model flag in run_previews.ps1 to use a different model.
OPENROUTER_API_KEY=your_openrouter_api_key_here
